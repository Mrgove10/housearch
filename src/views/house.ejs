<%
var headExtra = '<link href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" rel="stylesheet">' +
                '<script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>';
%>
<%- include('partials/head', { title: house.title || 'House', headExtra: headExtra }) %>
  <header class="appbar">
    <a href="/houses" class="icon-btn" style="text-decoration:none;display:inline-flex;align-items:center;justify-content:center">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 6-6 6 6 6"/></svg>
    </a>
    <h1>House</h1>
    <a href="/houses/<%= house.id %>/edit" class="icon-btn" style="text-decoration:none;display:inline-flex;align-items:center;justify-content:center" title="Edit">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>
    </a>
  </header>

  <main>
  <% if (house.archived) { %>
    <div class="flash err">Archived.
      <form method="post" action="/houses/<%= house.id %>/unarchive" class="inline-form"><button class="btn ghost" style="min-height:auto;padding:0 6px">Unarchive</button></form>
    </div>
  <% } %>
  <% if (readonly) { %>
    <div class="flash err">Declined — read-only.<% if (house.decline_reason) { %> Reason: <%= house.decline_reason %><% } %> Change status below to edit again.</div>
  <% } %>
  <div class="detail-grid">
    <div><!-- left col -->
      <div class="hero"<%- hero ? ' style="background-image:url(\'' + hero + '\')"' : '' %>></div>

      <!-- Timeline -->
      <div id="timeline" class="section-h" style="margin-top:18px"><h2>Timeline</h2></div>
      <div class="card">
        <% if (!readonly) { %>
        <form method="post" action="/houses/<%= house.id %>/notes" style="margin-bottom:10px">
          <div class="row">
            <input name="body" placeholder="Add a note…" style="flex:1" required>
            <button class="btn">Add note</button>
          </div>
        </form>
        <details style="margin-bottom:10px">
          <summary style="cursor:pointer;color:var(--accent);font-weight:600">Add event</summary>
          <form method="post" action="/houses/<%= house.id %>/events" class="mt">
            <div class="row">
              <select name="type">
                <% Object.entries(eventTypes).forEach(function([k,v]){ if(k!=='archived'&&k!=='status'){ %><option value="<%= k %>"><%= v %></option><% }}) %>
              </select>
              <input type="datetime-local" name="occurred_at">
            </div>
            <input name="note" placeholder="Note (optional)" class="mt">
            <button class="btn block mt">Add</button>
          </form>
        </details>
        <% } %>
        <% if (!events.length) { %><p class="muted">No events yet.</p><% } %>
        <div class="timeline">
          <% events.forEach(function(e){
               var cls = e.type==='visit_done'||e.type==='accepted'?'done':(e.type==='visit_scheduled'||e.type==='offer'?'warn':''); %>
          <div class="tl-item <%= cls %>">
            <div class="tl-date"><%= e.occurred_at %></div>
            <div class="tl-title">
              <%= e.label %>
              <% if (e.visit_id) { %><a href="/visits/<%= e.visit_id %>" style="font-weight:400;font-size:13px">· <%= e.type==='visit_scheduled' ? 'start' : 'open' %></a><% } %>
            </div>
            <% if (e.note) { %><div class="tl-body"><%= e.note %><% if (e.counts) { %> · <%= e.counts.np %> photos · <%= e.counts.nn %> notes<% } %></div><% } %>
            <% if (e.photos && e.photos.length) { %>
              <div class="photos">
                <% e.photos.forEach(function(ph){ %><a class="ph" href="/photos/<%= ph.path %>" target="_blank" style="background-image:url('/photos/<%= ph.path %>')"></a><% }) %>
              </div>
            <% } %>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Score -->
      <div id="score" class="section-h"><h2>Score breakdown</h2><a href="/settings#score">Edit criteria</a></div>
      <div class="card">
        <div class="checklist">
          <% scoreItems.forEach(function(it){ var on = scoreResp.get(it.id) ? true : false; %>
          <div class="item">
            <span><%= it.label %> <span class="muted" style="font-size:12px">(<%= it.sign>0?'+':'−' %><%= it.weight %>)</span></span>
            <% if (readonly) { %>
              <span class="muted"><%= on?'Yes':'No' %></span>
            <% } else { %>
              <button class="toggle-btn<%= on?' on':'' %>" data-score-url="/api/houses/<%= house.id %>/score/<%= it.id %>"><%= on?'Yes':'No' %></button>
            <% } %>
          </div>
          <% }) %>
          <% scoreCustom.forEach(function(c){ %>
          <div class="item">
            <span><%= c.label %></span>
            <span style="display:flex;gap:8px;align-items:center">
              <span class="score <%= scoreClass(c.points) %>"><%= scoreLabel(c.points) %></span>
              <% if (!readonly) { %><form method="post" action="/score/custom/<%= c.id %>/delete" class="inline-form"><button class="btn ghost" style="min-height:auto;padding:0 6px">✕</button></form><% } %>
            </span>
          </div>
          <% }) %>
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:10px;font-weight:700">
          <span>Total</span><span class="score <%= scoreClass(score.total) %>" data-score-total><%= scoreLabel(score.total) %></span>
        </div>
        <% if (!readonly) { %>
        <details class="mt">
          <summary style="cursor:pointer;color:var(--accent);font-weight:600">Add custom bonus/malus</summary>
          <form method="post" action="/houses/<%= house.id %>/score/custom" class="mt">
            <div class="row">
              <input name="label" placeholder="e.g. Cellar" style="flex:2">
              <input type="number" name="points" placeholder="±points" style="flex:1">
              <button class="btn">Add</button>
            </div>
          </form>
        </details>
        <% } %>
      </div>

      <!-- Photos -->
      <div id="photos" class="section-h"><h2>Photos</h2><span class="muted" style="font-size:13px"><%= photos.length %> total</span></div>
      <% if (!readonly) { %>
      <div class="dropzone" data-upload-url="/api/houses/<%= house.id %>/photos" data-preview-list="#house-upload">
        <strong>Drag &amp; drop images here</strong>
        <div>or <label for="hpick" style="color:var(--accent);text-decoration:underline;cursor:pointer">browse</label> · paste from clipboard</div>
        <input id="hpick" type="file" accept="image/*" multiple hidden>
      </div>
      <div id="house-upload" class="upload-list"></div>
      <% } %>
      <% if (photos.length) { %>
      <div class="photos mt">
        <% photos.forEach(function(ph){ %><a class="ph" href="/photos/<%= ph.path %>" target="_blank" style="background-image:url('/photos/<%= ph.path %>')"></a><% }) %>
      </div>
      <% } %>

    </div><!-- /left col -->

    <aside>
      <!-- 1. Title + link -->
      <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px">
          <div>
            <h2 style="margin:0;font-size:18px"><%= house.title %></h2>
            <div style="color:var(--muted);font-size:13px;margin-top:4px"><%= house.address || 'No address' %></div>
          </div>
          <div class="score <%= scoreClass(score.total) %>" data-score-total><%= scoreLabel(score.total) %></div>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:12px">
          <span class="price"><%= house.price ? Number(house.price).toLocaleString('fr-FR') + ' €' : '—' %></span>
          <% if (house.source_url) { %><a href="<%= house.source_url %>" target="_blank" class="btn ghost" style="padding:0;font-size:13px"><%= house.source_site || 'Source' %> ↗</a><% } %>
        </div>
        <dl class="kv" style="margin-top:14px">
          <% if (house.surface_m2) { %><dt>Surface</dt><dd><%= house.surface_m2 %> m²</dd><% } %>
          <% if (house.rooms) { %><dt>Rooms</dt><dd><%= house.rooms %><%= house.bedrooms ? ' (' + house.bedrooms + ' bed)' : '' %></dd><% } %>
          <% if (house.year_built) { %><dt>Year</dt><dd><%= house.year_built %></dd><% } %>
          <% if (house.dpe) { %><dt>DPE</dt><dd><%= house.dpe %></dd><% } %>
          <% if (house.lot_m2) { %><dt>Lot</dt><dd><%= house.lot_m2 %> m²</dd><% } %>
        </dl>
      </div>

      <!-- 2. Status -->
      <div class="card">
        <label>Status</label>
        <form method="post" action="/houses/<%= house.id %>/status">
          <select name="status" id="status-select" onchange="document.getElementById('decline-reason').style.display = this.value==='declined' ? '' : 'none'">
            <% Object.entries(statuses).forEach(function([k,v]){ %><option value="<%= k %>"<%= (!house.archived && house.status===k)?' selected':'' %>><%= v %></option><% }) %>
            <option value="archived"<%= house.archived?' selected':'' %>>Archived</option>
          </select>
          <input id="decline-reason" name="decline_reason" class="mt" placeholder="Reason for declining" value="<%= house.decline_reason || '' %>" style="<%= house.status==='declined' ? '' : 'display:none' %>">
          <button class="btn block mt">Update status</button>
        </form>
      </div>

      <!-- 3. Maps -->
      <div class="card">
        <% if (!readonly || (house.lat && house.lng)) { %>
        <label>Position <% if (!readonly) { %><span class="muted" style="font-weight:400">— click map to set</span><% } %></label>
        <div id="pos-map" data-house-id="<%= house.id %>" data-lat="<%= house.lat || '' %>" data-lng="<%= house.lng || '' %>" data-readonly="<%= readonly ? '1' : '' %>" style="height:180px;border-radius:12px;overflow:hidden;margin:6px 0"></div>
        <% } %>
        <% if (house.lat && house.lng) { %>
        <a href="/map?focus=<%= house.id %>" class="btn secondary block<%= readonly ? '' : ' mt' %>">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 3 3 6v15l6-3 6 3 6-3V3l-6 3-6-3z"/><path d="M9 3v15M15 6v15"/></svg>
          See on map
        </a>
        <div class="tags mt">
          <a class="tag" target="_blank" rel="noopener" href="https://immobilier.pappers.fr/?lat=<%= house.lat %>&lon=<%= house.lng %>&z=18.68">Pappers ↗</a>
          <a class="tag" target="_blank" rel="noopener" href="https://satellites.pro/France_map#<%= house.lat %>,<%= house.lng %>,18">Satellites.pro ↗</a>
          <a class="tag" target="_blank" rel="noopener" href="https://www.openstreetmap.org/?mlat=<%= house.lat %>&mlon=<%= house.lng %>#map=18/<%= house.lat %>/<%= house.lng %>">OpenStreetMap ↗</a>
          <a class="tag" target="_blank" rel="noopener" href="https://www.google.com/maps/search/?api=1&query=<%= house.lat %>,<%= house.lng %>">Google Maps ↗</a>
        </div>
        <% } else if (readonly) { %>
        <p class="muted" style="margin:0">No position set.</p>
        <% } %>
      </div>

      <!-- 4. Rest -->
      <div class="card">
        <% if (!readonly) { %>
        <details>
          <summary class="btn block" style="cursor:pointer">Plan visit</summary>
          <form method="post" action="/houses/<%= house.id %>/visits" class="mt">
            <label>When</label>
            <input type="datetime-local" name="scheduled_at">
            <label>With whom</label>
            <input name="with_whom" placeholder="Partner, agent…">
            <button class="btn block mt">Create visit</button>
          </form>
        </details>
        <% } %>
        <a href="#timeline" class="btn secondary block mt">Add note</a>
      </div>

      <% if (visits.length) { %>
      <div class="card">
        <div class="muted" style="font-size:12px;text-transform:uppercase;letter-spacing:.04em;margin-bottom:8px">Visits</div>
        <% visits.forEach(function(v){ %>
          <a href="/visits/<%= v.id %>" style="display:flex;justify-content:space-between;padding:6px 0;color:inherit">
            <span><%= v.done_at ? 'Done' : 'Planned' %></span>
            <span class="muted"><%= (v.done_at || v.scheduled_at || v.created_at || '').slice(0,16) %></span>
          </a>
        <% }) %>
      </div>
      <% } %>
    </aside>
  </div>
  </main>

  <%- include('partials/nav', { active: 'list' }) %>

  <script>
  (function () {
    const el = document.getElementById('pos-map');
    if (!el || typeof maplibregl === 'undefined') return;
    const houseId = el.dataset.houseId;
    const ro = el.dataset.readonly === '1';
    const has = el.dataset.lat !== '' && el.dataset.lng !== '';
    const start = has ? [parseFloat(el.dataset.lng), parseFloat(el.dataset.lat)] : [2.4, 46.6];
    const MAPTILER = <%- JSON.stringify(maptilerKey || '') %>;
    const rasterStyle = {
      version: 8,
      sources: { osm: { type: 'raster', tiles: ['https://a.tile.openstreetmap.org/{z}/{x}/{y}.png'], tileSize: 256, attribution: '© OpenStreetMap' } },
      layers: [{ id: 'osm', type: 'raster', source: 'osm' }],
    };
    const style = MAPTILER ? 'https://api.maptiler.com/maps/streets-v2/style.json?key=' + MAPTILER : rasterStyle;
    const map = new maplibregl.Map({ container: 'pos-map', style, center: start, zoom: has ? 14 : 5 });
    map.addControl(new maplibregl.NavigationControl(), 'top-right');
    const marker = new maplibregl.Marker({ draggable: !ro });
    if (has) marker.setLngLat(start).addTo(map);
    if (ro) return; // declined: show position only, no editing

    function save(lngLat) {
      fetch('/houses/' + houseId + '/position', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ lat: lngLat.lat, lng: lngLat.lng }),
      }).catch(() => {});
    }
    map.on('click', (e) => { marker.setLngLat(e.lngLat).addTo(map); save(e.lngLat); });
    marker.on('dragend', () => save(marker.getLngLat()));
  })();
  </script>
<%- include('partials/foot') %>
