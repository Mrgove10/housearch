<%- include('partials/head', { title: 'Settings — Housearch' }) %>
  <header class="appbar"><h1>Settings</h1></header>

  <main>
    <% if (flash) { %><div class="flash ok"><%= flash %></div><% } %>
    <% if (error) { %><div class="flash err"><%= error %></div><% } %>

    <!-- Checklist templates -->
    <div id="checklist" class="section-h"><h2>Checklist templates</h2></div>
    <div class="card">
      <div class="checklist">
        <% templates.forEach(function(t){ %>
          <div class="item">
            <a href="/settings/checklist/<%= t.id %>" style="color:inherit"><%= t.name %> <span class="muted">(<%= t.n %> items)</span></a>
            <form method="post" action="/checklist/templates/<%= t.id %>/delete" class="inline-form"><button class="btn ghost" style="min-height:auto;padding:0 6px">✕</button></form>
          </div>
        <% }) %>
      </div>
      <form method="post" action="/checklist/templates" class="row mt">
        <input name="name" placeholder="New template name" style="flex:2">
        <button class="btn">Add</button>
      </form>
    </div>

    <!-- Score criteria -->
    <div id="score" class="section-h"><h2>Score criteria</h2></div>
    <div class="card">
      <div class="checklist">
        <% scoreItems.forEach(function(s){ %>
          <div class="item">
            <span><%= s.label %></span>
            <span style="display:flex;gap:8px;align-items:center">
              <span class="tag accent">weight <%= s.weight %> · <%= s.sign>0?'+':'−' %></span>
              <form method="post" action="/score/template/<%= s.id %>/delete" class="inline-form"><button class="btn ghost" style="min-height:auto;padding:0 6px">✕</button></form>
            </span>
          </div>
        <% }) %>
      </div>
      <form method="post" action="/score/template" class="mt">
        <div class="row">
          <input name="label" placeholder="Criterion" style="flex:2">
          <input type="number" name="weight" placeholder="weight" value="1" min="1" style="flex:1">
          <select name="sign" style="flex:1"><option value="1">Bonus +</option><option value="-1">Malus −</option></select>
          <button class="btn">Add</button>
        </div>
      </form>
    </div>

    <!-- Map tiles -->
    <div id="map" class="section-h"><h2>Map tiles</h2></div>
    <div class="card">
      <p class="muted" style="margin-top:0">The map auto-fits to show all your houses.</p>
      <form method="post" action="/settings/map">
        <label>MapTiler key (optional, nicer tiles)</label>
        <input name="maptiler_key" value="<%= maptilerKey %>" placeholder="leave blank for OSM raster">
        <button class="btn block mt">Save</button>
      </form>
    </div>

    <!-- Data -->
    <div id="data" class="section-h"><h2>Data</h2></div>
    <div class="card">
      <a href="/settings/export" class="btn secondary block">Export backup (.zip)</a>
      <form method="post" action="/settings/import" enctype="multipart/form-data" class="mt"
            onsubmit="return confirm('Importing replaces ALL current houses, visits, photos and settings with the backup contents. Continue?')">
        <label>Restore backup (.zip)</label>
        <input type="file" name="backup" accept=".zip,application/zip" required>
        <button class="btn block mt">Import backup</button>
      </form>
      <div class="muted" style="font-size:13px;margin-top:10px"><%= stats.houses %> houses · <%= stats.archived %> archived · <%= stats.photos %> photos</div>
    </div>

    <div style="height:24px"></div>
  </main>

  <%- include('partials/nav', { active: 'settings' }) %>
<%- include('partials/foot') %>
